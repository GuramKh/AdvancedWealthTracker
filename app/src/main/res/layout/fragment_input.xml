<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/background">

    <!-- Title -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/gk_li_tv_input_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/input_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <View
        android:id="@+id/gk_li_divider_input"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/primary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/gk_li_tv_input_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Income label -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/gk_li_tv_label_income"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/label_income"
        android:textSize="14sp"
        android:textColor="@color/on_surface_medium"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/gk_li_divider_input"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Income EditText  (ID: gk_li_et_income) -->
    <EditText
        android:id="@+id/gk_li_et_income"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="e.g. 3500.00"
        android:inputType="numberDecimal"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="@drawable/et_background"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/gk_li_tv_label_income"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Expenses label -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/gk_li_tv_label_expenses"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/label_expenses"
        android:textSize="14sp"
        android:textColor="@color/on_surface_medium"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/gk_li_et_income"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Expenses EditText  (ID: gk_li_et_expenses) -->
    <EditText
        android:id="@+id/gk_li_et_expenses"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="e.g. 2000.00"
        android:inputType="numberDecimal"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="@drawable/et_background"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/gk_li_tv_label_expenses"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Save / Calculate button  (ID: gk_li_btn_save) -->
    <Button
        android:id="@+id/gk_li_btn_save"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_calculate"
        android:textSize="16sp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/gk_li_et_expenses"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hint for vertical swipe -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/gk_li_tv_swipe_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/swipe_hint"
        android:textSize="12sp"
        android:textColor="@color/on_surface_medium"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/gk_li_btn_save"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
