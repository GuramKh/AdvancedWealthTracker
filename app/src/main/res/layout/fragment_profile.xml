<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/background">

    <!-- Title -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/gk_li_tv_profile_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/profile_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/gk_li_divider_profile"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/primary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/gk_li_tv_profile_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Student name -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/gk_li_tv_profile_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="17sp"
        android:textColor="@color/on_surface"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/gk_li_divider_profile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/gk_li_tv_profile_surname"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="17sp"
        android:textColor="@color/on_surface"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/gk_li_tv_profile_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/gk_li_tv_profile_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="17sp"
        android:textColor="@color/on_surface"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/gk_li_tv_profile_surname"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/gk_li_tv_profile_prefix"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/on_surface_medium"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/gk_li_tv_profile_group"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/gk_li_tv_profile_orientation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/on_surface_medium"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/gk_li_tv_profile_prefix"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- K formula card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/gk_li_card_formula"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/card_background"
        app:layout_constraintTop_toBottomOf="@id/gk_li_tv_profile_orientation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/gk_li_tv_card_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="K Coefficient Formula"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/gk_li_tv_profile_formula"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/on_surface"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/gk_li_tv_card_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/gk_li_tv_profile_k_result"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/gk_li_tv_profile_formula"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/gk_li_tv_profile_savings_formula"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/on_surface_medium"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/gk_li_tv_profile_k_result"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
